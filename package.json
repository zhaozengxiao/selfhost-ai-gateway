{
  "name": "ai-gateway",
  "version": "2.0.0",
  "description": "AI API Gateway (Node.js + Hono + SQLite, Docker-ready)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "ai",
    "proxy",
    "api-gateway",
    "hono",
    "sqlite",
    "docker"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.2",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.20.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
